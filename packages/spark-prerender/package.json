{
  "name": "spark-prerender",
  "version": "0.1.0",
  "description": "Build-time prerender (SEO) for spark-html — reuses the real runtime, no SSR server, no app-code changes.",
  "type": "module",
  "main": "./src/prerender.js",
  "exports": {
    ".": {
      "default": "./src/prerender.js"
    }
  },
  "bin": {
