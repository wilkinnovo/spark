  },
  "scripts": {
    "test": "node test/prerender.js"
  },
  "files": [
    "src",
    "bin"
  ],
  "dependencies": {
    "linkedom": "^0.18.12",
    "spark-html": "*"
  },
  "keywords": [
    "spark-html",
    "prerender",
    "ssg",
    "seo",
    "static"
  ],
  "license": "MIT"
}
